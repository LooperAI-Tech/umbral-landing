# .env.docker
# Docker Compose environment variables template
# Copy this to .env for local development: cp .env.docker .env

# ========================================
# PostgreSQL Configuration
# ========================================
POSTGRES_USER=umbral
POSTGRES_PASSWORD=umbral_dev_password
POSTGRES_DB=umbral_db

# ========================================
# Backend Configuration
# ========================================
APP_NAME=Umbral EdTech API
DEBUG=true
SECRET_KEY=docker-dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========================================
# Authentication (Clerk)
# ========================================
# Get these from https://dashboard.clerk.com
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# ========================================
# AI Model API Keys
# ========================================
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ========================================
# API Configuration
# ========================================
RATE_LIMIT_PER_MINUTE=60
DEFAULT_AI_MODEL=gpt-4
MAX_TOKENS_PER_REQUEST=4000
AI_TEMPERATURE=0.7
